DRAMATYPE_AGENT_MODE=rule_based

# ── LLM Provider ──────────────────────────────────────────
# Supported: anthropic, openai, deepseek, qwen, kimi, zhipu,
#            siliconflow, custom_openai_compatible, xiaomi (alias: mimo)
LLM_PROVIDER=anthropic
LLM_MODEL=
# Optional: override provider default base URL
LLM_BASE_URL=
# For custom_openai_compatible provider:
LLM_API_KEY=

# ── Per-Provider API Keys ─────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
MOONSHOT_API_KEY=
ZHIPUAI_API_KEY=
SILICONFLOW_API_KEY=
XIAOMI_API_KEY=

# ── Default Models (per provider) ─────────────────────────
# anthropic:  claude-sonnet-4-20250514
# openai:     gpt-4o
# deepseek:   deepseek-chat
# qwen:       qwen-plus (also try qwen-max, qwen-long)
# kimi:       kimi-k2.5
# zhipu:      glm-5.1
# siliconflow: Qwen/Qwen3-8B (set LLM_MODEL for other models)
# xiaomi:     mimo-v2.5-pro (also try mimo-v2.5, mimo-v2-pro, mimo-v2-flash)
# Override any default with LLM_MODEL=your-model-name

# ── RAG ───────────────────────────────────────────────────
INPUT_FILENAME=wugang_letters_material.md
OUTPUT_FILENAME=wugang_letters_content_pack.json
RAG_ENABLED=true
VECTOR_STORE_PROVIDER=chroma
EMBEDDING_PROVIDER=keyword
CHROMA_PERSIST_DIR=data/vector_store/chroma
